rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /system/{doc} {
      allow read, write: if request.auth != null;
    }

    match /commands/{doc} {
      allow read, write: if request.auth != null;
    }

    match /scan_history/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
